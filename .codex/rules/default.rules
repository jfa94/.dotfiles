# Command autonomy rules mirroring the safe parts of .claude/settings.json.
#
# Codex prefix rules match exact argv prefixes. They do not support Claude's
# Bash(*) wildcards or arbitrary-position flag matching, so hooks remain the
# backstop for force-push, bypass-flag, rm, package-publish, and SQL patterns.

READ_SHELL_COMMANDS = [
    "cat",
    "echo",
    "head",
    "ls",
    "tail",
    "wc",
    "which",
    "pwd",
    "find",
    "sort",
    "uniq",
    "diff",
    "file",
    "basename",
    "dirname",
    "realpath",
    "whoami",
    "uname",
    "env",
    "printenv",
    "tree",
    "touch",
    "tr",
    "cut",
    "xargs",
    "tee",
    "sed",
    "jq",
    "grep",
    "rg",
    "mkdir",
    "shellcheck",
]

HELPABLE_COMMANDS = READ_SHELL_COMMANDS + [
    "node",
    "pnpm",
    "npm",
    "yarn",
    "tsc",
    "next",
    "git",
    "gh",
    "aws",
]

GIT_COMMANDS = [
    "add",
    "mv",
    "commit",
    "checkout",
    "branch",
    "stash",
    "push",
    "diff",
    "log",
    "show",
    "check-ignore",
    "blame",
    "fetch",
    "rev-parse",
    "shortlog",
    "reflog",
    "describe",
    "remote",
    "config",
    "ls-files",
    "ls-remote",
    "ls-tree",
    "cherry",
    "merge-base",
    "tag",
    "rebase",
    "worktree",
    "status",
]

PNPM_COMMANDS = [
    "install",
    "run",
    "dev",
    "test",
    "build",
    "next",
    "list",
    "ls",
    "why",
    "outdated",
    "audit",
    "exec",
    "tsc",
    "vitest",
    "typecheck",
    "lint",
    "eslint",
    "prettier",
    "depcruise",
    "stryker",
    "tsc-alias",
    "madge",
    "dlx",
    "quality",
    "deps:validate",
    "test:coverage",
    "test:mutation",
    "format",
]

# Hard policy denies. Prefix rules can't match a +refspec force-push
# (`git push origin +branch`) at arbitrary argv positions — the
# dangerous-patterns-check hook is the backstop for that form.
prefix_rule(
    pattern = ["git", "push", "--force"],
    decision = "forbidden",
    justification = "Force-push is blocked. Push normally or ask the user for a branch repair plan.",
    match = ["git push --force origin main"],
)

prefix_rule(
    pattern = ["git", "push", "-f"],
    decision = "forbidden",
    justification = "Force-push is blocked. Push normally or ask the user for a branch repair plan.",
    match = ["git push -f origin main"],
)

prefix_rule(
    pattern = ["git", "push", "--force-with-lease"],
    decision = "forbidden",
    justification = "Force-push is blocked, including force-with-lease. Push normally or ask the user for a branch repair plan.",
    match = ["git push --force-with-lease origin main"],
)

prefix_rule(
    pattern = ["git", "push", "--force-if-includes"],
    decision = "forbidden",
    justification = "Force-push is blocked, including force-if-includes. Push normally or ask the user for a branch repair plan.",
    match = ["git push --force-if-includes origin main"],
)

prefix_rule(
    pattern = ["git", "push", "--no-verify"],
    decision = "forbidden",
    justification = "Do not bypass git hooks. Fix the underlying check.",
    match = ["git push --no-verify origin main"],
)

prefix_rule(
    pattern = ["git", "commit", "--no-verify"],
    decision = "forbidden",
    justification = "Do not bypass git hooks. Fix the underlying check.",
    match = ["git commit --no-verify -m test"],
)

prefix_rule(
    pattern = ["git", "commit", "-n"],
    decision = "forbidden",
    justification = "Do not bypass git hooks. Fix the underlying check.",
    match = ["git commit -n -m test"],
)

prefix_rule(
    pattern = ["git", "commit", "--no-gpg-sign"],
    decision = "forbidden",
    justification = "Do not bypass commit signing policy.",
    match = ["git commit --no-gpg-sign -m test"],
)

prefix_rule(
    pattern = ["git", "rebase", "--no-verify"],
    decision = "forbidden",
    justification = "Do not bypass git hooks. Fix the underlying check.",
    match = ["git rebase --no-verify main"],
)

prefix_rule(
    pattern = ["pnpm", "publish"],
    decision = "forbidden",
    justification = "Package publishing is blocked.",
    match = ["pnpm publish"],
)

prefix_rule(
    pattern = ["npm", "publish"],
    decision = "forbidden",
    justification = "Package publishing is blocked. Use pnpm for local package-manager commands.",
    match = ["npm publish"],
)

prefix_rule(
    pattern = ["yarn", "publish"],
    decision = "forbidden",
    justification = "Package publishing is blocked. Use pnpm for local package-manager commands.",
    match = ["yarn publish"],
)

prefix_rule(
    pattern = ["rm", "-rf", "/"],
    decision = "forbidden",
    justification = "Destructive root delete is blocked.",
    match = ["rm -rf /"],
)

prefix_rule(
    pattern = ["rm", "-rf"],
    decision = "prompt",
    justification = "Recursive forced deletes require explicit review of the target.",
    match = ["rm -rf build"],
)

prefix_rule(
    pattern = ["rm", "-fr"],
    decision = "prompt",
    justification = "Recursive forced deletes require explicit review of the target.",
    match = ["rm -fr build"],
)

prefix_rule(
    pattern = [["dropdb", "mysqladmin"]],
    decision = "prompt",
    justification = "Database administration commands require explicit review; destructive SQL is blocked by hooks where visible.",
    match = ["dropdb app_test"],
)

prefix_rule(
    pattern = [["psql", "mysql", "sqlite3"]],
    decision = "prompt",
    justification = "Interactive database clients require explicit review; destructive SQL is blocked by hooks where visible.",
    match = ["psql app_test"],
)

# Basic read/list/text utilities and help/version probes.
prefix_rule(
    pattern = [HELPABLE_COMMANDS, ["--help", "--version"]],
    decision = "allow",
    justification = "Help and version probes are routine.",
)

prefix_rule(
    pattern = [READ_SHELL_COMMANDS],
    decision = "allow",
    justification = "Common shell read/list/text utilities are allowed by the Claude config.",
    match = ["ls", "jq --version", "sed -n 1,10p file.ts"],
)

# Node, TypeScript, Next.js, and pnpm project commands.
prefix_rule(
    pattern = ["node", "--check"],
    decision = "allow",
    justification = "Node syntax checks are safe local validation.",
    match = ["node --check script.js"],
)

prefix_rule(
    pattern = ["node", "-v"],
    decision = "allow",
    justification = "Version probe; the long form is covered by the help/version rule.",
    match = ["node -v"],
)

prefix_rule(
    pattern = [["python3", "python"], "-m", "json.tool"],
    decision = "allow",
    justification = "JSON pretty-printing is read-only; mirrors Claude's allowlist.",
    match = ["python3 -m json.tool file.json"],
)

prefix_rule(
    pattern = [["tsc", "next"]],
    decision = "allow",
    justification = "TypeScript and Next.js project commands are allowed by the Claude config.",
    match = ["tsc --noEmit", "next build"],
)

prefix_rule(
    pattern = ["pnpm", PNPM_COMMANDS],
    decision = "allow",
    justification = "Project install, dev, build, test, lint, quality, and inspection commands are allowed by the Claude config.",
    match = [
        "pnpm test",
        "pnpm install --frozen-lockfile",
        "pnpm run build",
        "pnpm dlx vitest run",
    ],
)

# Git commands. Dynamic `git -C <path> <command>` forms remain unmatched and
# therefore prompt; allowing `git -C` would permit arbitrary subcommands.
prefix_rule(
    pattern = ["git", GIT_COMMANDS],
    decision = "allow",
    justification = "Git inspection and routine branch/stage/commit/push commands are allowed by the Claude config; hooks enforce dangerous flag denies.",
    match = [
        "git status",
        "git add file.ts",
        "git commit -m test",
        "git push origin main",
    ],
)

# GitHub CLI parity with Claude's allowlist. PR mutation safety remains covered
# by pre-pr hooks and repository instructions.
prefix_rule(
    pattern = ["gh", "pr", ["create", "merge", "list", "view", "diff", "status", "checks"]],
    decision = "allow",
    justification = "GitHub PR commands mirror Claude's allowlist; non-draft PR creation is gated by hooks.",
    match = ["gh pr view 1", "gh pr create --draft"],
)

prefix_rule(
    pattern = ["gh", "pr", ["ready", "close"]],
    decision = "prompt",
    justification = "PR readiness and close operations require a fresh decision.",
    match = ["gh pr ready 1", "gh pr close 1"],
)

prefix_rule(
    pattern = ["gh", "issue", ["list", "view", "status", "comment", "create", "clone"]],
    decision = "allow",
    justification = "GitHub issue commands mirror Claude's allowlist.",
)

prefix_rule(
    pattern = ["gh", "repo", "view"],
    decision = "allow",
    justification = "Repository inspection is routine.",
)

prefix_rule(
    pattern = ["gh", "run", ["list", "view"]],
    decision = "allow",
    justification = "GitHub Actions run inspection is routine.",
)

prefix_rule(
    pattern = ["gh", "release", ["list", "view"]],
    decision = "allow",
    justification = "Release inspection is routine.",
)

prefix_rule(
    pattern = ["gh", "api"],
    decision = "prompt",
    justification = "Claude removed gh api from its allowlist (arbitrary REST verbs, including mutations); prompt per call.",
)

# AWS read allowlist lives in aws-read.rules (generated by generate-aws-read.sh):
# per-op allow rules for actively used services. Everything else — writes and
# unlisted services — falls through to Codex's approval prompt. The
# aws-readonly-check hook only hard-denies secretsmanager secret-value reads.
prefix_rule(
    pattern = ["aws", "help"],
    decision = "allow",
    justification = "AWS CLI help is safe.",
)

prefix_rule(
    pattern = ["aws", "s3", "ls"],
    decision = "allow",
    justification = "S3 listing is read-only.",
    match = ["aws s3 ls"],
)

prefix_rule(
    pattern = ["aws", "s3", "cp"],
    decision = "prompt",
    justification = "S3 copy can write locally or remotely; prefix rules can't distinguish the streaming-to-stdout form Claude auto-allows, so every cp prompts.",
    match = ["aws s3 cp s3://bucket/key -"],
)
prefix_rule(pattern=["pnpm", "test:pg"], decision="allow")
prefix_rule(pattern=["gh", "auth", "status"], decision="allow")

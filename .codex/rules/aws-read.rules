# GENERATED by generate-aws-read.sh from 'aws <service> help' — do not hand-edit.
# Read ops for actively used AWS services auto-allow; every other AWS command
# (writes, unlisted services) falls through to Codex's approval prompt.
# aws-readonly-check.sh still hard-denies secretsmanager secret-value reads.


{
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/codex-dir-check.sh",
            "statusMessage": "Checking Codex config access"
          }
        ]
      },
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/protected-files-check.sh",
            "statusMessage": "Checking protected files and migrations"
          }
        ]
      },
      {
        "matcher": "mcp__.*[Ss]upabase.*execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/sql-readonly-check.sh",
            "statusMessage": "Checking SQL is read-only"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/compound-check.sh",
            "statusMessage": "Checking command structure"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/dangerous-patterns-check.sh",
            "statusMessage": "Checking dangerous patterns"
          },
          {
            "type": "command",
            "command": "bash $HOME/.codex/hooks/aws-readonly-check.sh",
            "statusMessage": "Checking AWS command is read-only"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/npm-to-pnpm.sh",
            "statusMessage": "Rewriting npm to pnpm"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/pre-commit-check.sh",
            "timeout": 60,
            "statusMessage": "Running pre-commit checks"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/pre-push-check.sh",
            "timeout": 900,
            "statusMessage": "Running pre-push quality gate"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/semgrep-check.sh",
            "timeout": 120,
            "statusMessage": "Running Semgrep gate"
          },
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/pre-pr-check.sh",
            "timeout": 1800,
            "statusMessage": "Running PR mutation gate"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "$HOME/.codex/hooks/prettier-format.sh",
            "timeout": 15,
            "statusMessage": "Formatting changed files"
          }
        ]
      }
    ]
  }
}

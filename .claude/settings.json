  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-dir-check.sh",
            "statusMessage": "Checking .claude/ directory access"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protected-files-check.sh",
            "statusMessage": "Checking protected files & migrations"
          }
        ]
      },
      {
        "matcher": "mcp__.*[Ss]upabase.*__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sql-readonly-check.sh",
            "statusMessage": "Checking SQL is read-only"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/compound-check.sh",
            "statusMessage": "Checking for compound commands"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-patterns-check.sh",
            "statusMessage": "Checking for dangerous patterns"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/npm-to-pnpm.sh",
            "statusMessage": "Rewriting npm → pnpm"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-check.sh",
            "timeout": 60,
            "statusMessage": "Running pre-commit checks"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-push-check.sh",
            "timeout": 900,
            "statusMessage": "Running quality checks before push"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/semgrep-check.sh",
            "timeout": 120,
            "statusMessage": "Running semgrep SAST scan before push"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-pr-check.sh",
            "timeout": 1800,
            "statusMessage": "Running mutation gate before PR"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/prettier-format.sh",
            "timeout": 15,
            "statusMessage": "Auto-formatting with prettier"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "startup",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-model-lock.sh",
            "statusMessage": "Locking default model to opusplan"
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-keep-awake.sh",
            "statusMessage": "Preventing Windows sleep for this session"
          }
        ]
      },
      {
        "matcher": "compact",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionstart-compact-restore.sh",
            "timeout": 15,
            "statusMessage": "Restoring pre-compaction context"
          },
          {
            "type": "command",
            "command": "~/.claude/hooks/superpowers-compact-reinject.sh",
            "timeout": 10,
            "statusMessage": "Re-arming superpowers after compaction"
          }
        ]
      }
    ],
    "SessionEnd": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sessionend-keep-awake.sh",
            "statusMessage": "Releasing Windows sleep-prevention"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": false,
    "plugin-dev@claude-plugins-official": false,
    "frontend-design@claude-plugins-official": false,
    "playwright@claude-plugins-official": false,
    "supabase@claude-plugins-official": false,
    "stripe@claude-plugins-official": false,
    "posthog@claude-plugins-official": false,
    "figma@claude-plugins-official": false,
    "resend@claude-plugins-official": false,
    "codex@openai-codex": true,
    "factory@jfa94": true,
    "ponytail@ponytail": true,
    "aws-serverless@claude-plugins-official": false
  },
  "extraKnownMarketplaces": {
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "jfa94": {
      "source": {
        "source": "github",
        "repo": "jfa94/factory"
      }
    },
    "ponytail": {
      "source": {
        "source": "github",
        "repo": "DietrichGebert/ponytail"
      }
    }
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "tui": "fullscreen",
  "skipWorkflowUsageWarning": true,
  "theme": "dark",
  "remoteControlAtStartup": true,
  "agentPushNotifEnabled": true,
  "skipAutoPermissionPrompt": true,
  "autoMode": {
    "allow": [
      "$defaults"
    ],
    "soft_deny": [
      "Never modify or delete existing tests to make them pass. Fix the implementation instead.",
      "Never disable, downgrade, or skip lint/typecheck/test/quality gates to silence errors.",
      "Never write fallback code that silently degrades functionality; surface the error.",
      "Never hardcode return values to satisfy specific test inputs.",
      "Never DROP, TRUNCATE, or run unbounded DELETE/UPDATE on any database; never drop a database table.",
      "Never run apply_migration or schema-changing SQL against a Supabase project without explicit user confirmation in this turn.",
      "Never write secrets, API keys, or tokens into source files. Use .env* files only.",
      "Never modify .env, .env.*, or credential files without explicit confirmation.",
      "Never use --no-verify, --no-gpg-sign, -n, or any flag that bypasses git hooks or signing.",
      "Never force-push in any form (--force, -f, --force-with-lease, --force-if-includes); these are hard-denied at the permissions layer.",
      "Never push, merge, or close PRs on repos other than dotfiles without explicit confirmation. (Dotfiles repo: direct commits to main are pre-approved.)",
      "Never run destructive AWS mutations (delete-*, terminate-*, or put-* on production resources) without confirmation.",
      "Never publish packages (pnpm/npm/yarn publish) under any circumstance.",
      "Never disable or rewrite the protected-files, dangerous-patterns, sql-readonly, or pre-commit/pre-push/pre-pr hooks.",
      "Never open a non-draft PR (gh pr create without --draft, or gh pr ready) without the mutation gate passing; the pre-pr-check hook enforces this."
    ],
    "environment": [
      "Trusted local repos: anything under /Users/Javier/.dotfiles and /Users/Javier/Projects/*.",
      "Trusted package registries: npm, pnpm, GitHub.",
      "PostHog project 'Outsidey' (id 107700) is the user's own project; reads are safe, writes require explicit ask.",
      "Supabase: list/read tools are safe; execute_sql is gated by the sql-readonly-check hook; apply_migration is production-impacting and must always confirm with the user first."
    ]
  }
}

  "model": "opusplan",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/claude-dir-check.sh",
            "statusMessage": "Checking .claude/ directory access"
          }
        ]
      },
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/protected-files-check.sh",
            "statusMessage": "Checking protected files & migrations"
          }
        ]
      },
      {
        "matcher": "mcp__plugin_supabase_supabase__execute_sql",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/sql-readonly-check.sh",
            "statusMessage": "Checking SQL is read-only"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/compound-check.sh",
            "statusMessage": "Checking for compound commands"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/dangerous-patterns-check.sh",
            "statusMessage": "Checking for dangerous patterns"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/native-tool-nudge.sh",
            "statusMessage": "Checking for native tool alternatives"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/npm-to-pnpm.sh",
            "statusMessage": "Rewriting npm → pnpm"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-commit-check.sh",
            "timeout": 60,
            "statusMessage": "Running pre-commit checks"
          }
        ]
      },
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/hooks/pre-push-check.sh",
            "timeout": 900,
            "statusMessage": "Running quality checks before push"
          }
        ]
      },
      {
        "matcher": "Read",
        "hooks": [
          {
            "type": "command",
            "command": "~/.claude/read-once/hook.sh",
            "statusMessage": "Tracking read-once files"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": "FILE=$(cat | jq -r '.tool_input.file_path'); npx prettier --write \"$FILE\" 2>/dev/null; echo '{\"suppressOutput\": true}'",
            "timeout": 15,
            "statusMessage": "Auto-formatting with prettier"
          }
        ]
      }
    ]
  },
  "statusLine": {
    "type": "command",
    "command": "~/.claude/statusline.sh"
  },
  "enabledPlugins": {
    "typescript-lsp@claude-plugins-official": true,
    "commit-commands@claude-plugins-official": true,
    "security-guidance@claude-plugins-official": true,
    "pr-review-toolkit@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "feature-dev@claude-plugins-official": true,
    "code-review@claude-plugins-official": true,
    "code-simplifier@claude-plugins-official": true,
    "frontend-design@claude-plugins-official": true,
    "playground@claude-plugins-official": true,
    "claude-md-management@claude-plugins-official": true,
    "plugin-dev@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "figma@claude-plugins-official": true,
    "posthog@claude-plugins-official": true,
    "superpowers@claude-plugins-official": true,
    "stripe@claude-plugins-official": true,
    "caveman@caveman": true,
    "codex@openai-codex": true,
    "factory@jfa94": true
  },
  "extraKnownMarketplaces": {
    "caveman": {
      "source": {
        "source": "github",
        "repo": "JuliusBrussee/caveman"
      }
    },
    "openai-codex": {
      "source": {
        "source": "github",
        "repo": "openai/codex-plugin-cc"
      }
    },
    "jfa94": {
      "source": {
        "source": "github",
        "repo": "jfa94/factory"
      }
    }
  },
  "effortLevel": "medium",
  "awaySummaryEnabled": false,
  "skipAutoPermissionPrompt": true
}

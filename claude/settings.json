            "mcp__plugin_posthog_posthog__docs-search",
            "mcp__plugin_posthog_posthog__get-llm-total-costs-for-project"
        ]
    },
    "hooks": {
        "PreToolUse": [
            {
                "matcher": "Edit|Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "BRANCH=$(git branch --show-current 2>/dev/null); if [ \"$BRANCH\" = \"main\" ] || [ \"$BRANCH\" = \"master\" ]; then echo '{\"decision\":\"block\",\"reason\":\"Cannot edit on main/master. Create a feature branch first.\"}'; exit 0; fi"
                    }
                ]
            },
            {
                "matcher": "mcp__plugin_supabase_supabase__execute_sql",
                "hooks": [
                    {
                        "type": "command",
                        "command": "SQL=$(cat | jq -r '.tool_input.sql // .tool_input.query // \"\"' | tr '[:lower:]' '[:upper:]'); for KW in INSERT UPDATE DELETE DROP ALTER TRUNCATE CREATE GRANT REVOKE COMMENT; do if echo \"$SQL\" | grep -qw \"$KW\"; then echo '{\"decision\":\"block\",\"reason\":\"Write SQL blocked. execute_sql is restricted to read-only (SELECT/SHOW/EXPLAIN/DESCRIBE).\"}'; exit 0; fi; done"
                    }
                ]
            }
        ],
        "PostToolUse": [
            {
                "matcher": "Write",
                "hooks": [
                    {
                        "type": "command",
                        "command": "FILE=$(cat | jq -r '.tool_input.file_path'); npx prettier --write \"$FILE\" 2>/dev/null; echo '{\"suppressOutput\": true}'",
                        "timeout": 15
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "cd $CLAUDE_PROJECT_DIR && npx tsc --noEmit 2>&1 | tail -20; TSC=$?; npx eslint . --max-warnings 0 2>&1 | tail -20; LINT=$?; npx vitest run --reporter=verbose 2>&1 | tail -40; TEST=$?; if [ $TSC -ne 0 ] || [ $LINT -ne 0 ] || [ $TEST -ne 0 ]; then echo 'QUALITY GATE FAILED: tsc('$TSC') lint('$LINT') test('$TEST'). Fix all issues.'; exit 1; fi",
                        "timeout": 120
                    }
                ]
            }
        ]
    }
}
